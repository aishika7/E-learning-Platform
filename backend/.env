PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/elearn
JWT_SECRET=elearn_super_secure_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=2d
CLIENT_URL=http://localhost:4200

# Email (Nodemailer - use Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-google-app-password
EMAIL_FROM=ELearn Platform <noreply@elearn.com>

# Payment (Demo Mode - no real transactions)
DEMO_PAYMENT_MODE=true
RAZORPAY_KEY_ID=rzp_test_demo_placeholder
RAZORPAY_SECRET=demo_secret_placeholder
